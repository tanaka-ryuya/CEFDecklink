                const g = parseInt(hex.substring(2, 4), 16);
                const b = parseInt(hex.substring(4, 6), 16);
                const a = parseInt(hex.substring(6, 8), 16) / 255;
                const color = "#" + hex.substring(0, 6);
                return { color, alpha: a, rgba: "rgba(" + r + ", " + g + ", " + b + ", " + a + ")" };
            }
