                        shadowGraphics.lineStyle({ width: currentThickness, color: sShadow.color, alpha: 1, join: appearance.lineJoin || 'miter', miterLimit: appearance.miterLimit || 10 });
                    }
                    drawShape(shadowGraphics, w, h, cornerRadius);
                    shadowGraphics.endFill();
                    shadowContainer.addChild(shadowGraphics);
                    if (!appearance.fillEnabled) {
                        const punch = new PIXI.Graphics();
                        punch.beginFill(0x000000, 1);
                        drawShape(punch, w, h, cornerRadius);
                        punch.endFill();
                        punch.blendMode = PIXI.BLEND_MODES.ERASE;
                        shadowContainer.addChild(punch);
                    }
                    if (appearance.shadowBlur && appearance.shadowBlur > 0) {
                        const blurFilter = new PIXI.filters.BlurFilter();
                        blurFilter.blur = appearance.shadowBlur;
                        shadowContainer.filters = [...shadowContainer.filters, blurFilter];
                    }
                    shadowContainer.x = appearance.shadowOffsetX || 0;
                    shadowContainer.y = appearance.shadowOffsetY || 0;
                    shadowContainer.alpha = appearance.shadowAlpha ?? sShadow.alpha;
                    appContainer.addChild(shadowContainer);
                }

                const mainObjectContainer = new PIXI.Container();
                mainObjectContainer.filters = [new PIXI.AlphaFilter(1)];
                if (appearance.strokeEnabled) {
                    const strokeGraphics = new PIXI.Graphics();
                    const sStroke = parseColor(appearance.color, '#000000');
                    strokeGraphics.lineStyle({ width: currentThickness, color: sStroke.color, alpha: sStroke.alpha, join: appearance.lineJoin || 'miter', miterLimit: appearance.miterLimit || 10 });
                    strokeGraphics.beginFill(0x000000, 0);
                    drawShape(strokeGraphics, w, h, cornerRadius);
                    strokeGraphics.endFill();
                    mainObjectContainer.addChild(strokeGraphics);
                }
                const rawFillForRect = appearance.fill || 0xffffff;
                const fillColorsForRect = Array.isArray(rawFillForRect) ? rawFillForRect : [rawFillForRect];
                const firstFillColorForRect = parseColor(fillColorsForRect[0], '#ffffff');
                if (appearance.strokeEnabled && (!appearance.fillEnabled || firstFillColorForRect.alpha < 1)) {
                    const punch = new PIXI.Graphics();
                    punch.beginFill(0x000000, 1);
                    drawShape(punch, w, h, cornerRadius);
                    punch.endFill();
                    punch.blendMode = PIXI.BLEND_MODES.ERASE;
                    mainObjectContainer.addChild(punch);
                }
                if (appearance.fillEnabled) {
                    const fillGraphics = new PIXI.Graphics();
                    if (appearance.gradientConfig) {
                        const canvas = document.createElement('canvas');
                        canvas.width = w; canvas.height = h;
                        const ctx = canvas.getContext('2d');
                        if (ctx) {
                            const gradient = ctx.createLinearGradient(0, 0, appearance.gradientConfig.type === 1 ? w : 0, appearance.gradientConfig.type === 0 ? h : 0);
                            appearance.gradientConfig.stops.forEach(s => gradient.addColorStop(Number(s.offset), s.color || '#000000'));
                            ctx.fillStyle = gradient;
                            ctx.fillRect(0, 0, w, h);
                            fillGraphics.beginTextureFill({ texture: PIXI.Texture.from(canvas) });
                        } else {
                            fillGraphics.beginFill(firstFillColorForRect.color, firstFillColorForRect.alpha);
                        }
                    } else {
                        fillGraphics.beginFill(firstFillColorForRect.color, firstFillColorForRect.alpha);
                    }
                    drawShape(fillGraphics, w, h, cornerRadius);
                    fillGraphics.endFill();
                    mainObjectContainer.addChild(fillGraphics);
                }
                appContainer.addChild(mainObjectContainer);
                const appearanceFilters = buildFilters(PIXI, appearance.effects, resolution, false);
                if (appearanceFilters.length > 0) appContainer.filters = appearanceFilters;
                if (appearance.isMask) {
                    const maskFilter = new PIXI.AlphaFilter(1);
                    maskFilter.blendMode = PIXI.BLEND_MODES.ERASE;
                    appContainer.filters = [maskFilter, ...(appContainer.filters || [])];
                }
                container.addChild(appContainer);
            });
        }

        container.x = node.x;
        container.y = node.y;
        container.scale.set(node.scaleX, node.scaleY);
        container.rotation = (node.rotation * Math.PI) / 180;
        container.alpha = node.opacity !== undefined ? node.opacity : 1;

        return container;
    }

    // ==========================================
    // Player Logic
    // ==========================================

    window.keyExpMap = new Map();
    window.telopApp = null;
    window.telopDoc = null;
    window.createNode = null;

    window.initPlayer = async function (containerId, projectData, assetCache) {
        window.containerId = containerId;
        window.telopDoc = projectData;

        // Init PIXI
        const width = projectData.meta.width || 1920;
        const height = projectData.meta.height || 1080;
        const app = new PIXI.Application({
            width, height,
            backgroundAlpha: 0,
            resolution: 2,
            autoDensity: true,
            antialias: true
        });
        window.telopApp = app;

        const container = document.getElementById(containerId);
        if (container) {
            container.appendChild(app.view);
        }

        // --- Create Node Helper (uses renderer functions) ---
        window.createNode = function (nodeId) {
            const node = projectData.nodesById[nodeId];
            if (!node) return null;

            let displayObject = null;
            if (node.type === 'text') {
                displayObject = createTextNode(PIXI, node);
            } else if (node.type === 'image') {
                const assetId = node.assetId;
                const asset = projectData.assets[assetId];
                if (asset) {
                    const src = asset.src;
                    // Resolve texture from cache (Base64) or URL
                    let textureSource = src;
                    if (assetCache && assetCache[src]) {
                        textureSource = assetCache[src];
                    }
                    const texture = PIXI.Texture.from(textureSource);
                    displayObject = createImageNode(PIXI, node, texture);
                }
            } else if (node.type === 'rect') {
                displayObject = createRectNode(PIXI, node);
            } else if (node.type === 'group' || node.type === 'telop' || node.type === 'plane') {
                displayObject = createGroupNode(PIXI, node);
            }

            if (displayObject) {
                if (node.children) {
                    node.children.forEach(childId => {
                        const childObj = window.createNode(childId);
                        if (childObj) displayObject.addChild(childObj);
                    });
                }

                // Register KeyExp
                if (node.keyexp) {
                    window.keyExpMap.set(node.keyexp, {
                        type: node.type,
                        nodeData: node
                    });
                }

                // Initial Visibility Hidden (Optional, usually handled by controller or CSS)
            }
            return displayObject;
        };

        // --- Initial Render ---
        const root = window.createNode(projectData.rootId);
        if (root) app.stage.addChild(root);

        // --- Animation Ticker for Effects ---
        app.ticker.add(() => {
            const updateTick = (cont) => {
                if (cont.filters) {
                    cont.filters.forEach(filter => {
                        if (PIXI.filters.GlitchFilter && filter instanceof PIXI.filters.GlitchFilter) {
                            filter.refresh();
                        } else if (PIXI.filters.GlowFilter && filter instanceof PIXI.filters.GlowFilter) {
                            const pulse = filter._pulseParams;
                            if (pulse && pulse.enabled) {
                                const now = Date.now();
                                if (!pulse.startTime) pulse.startTime = now;
                                const elapsedSeconds = (now - pulse.startTime) / 1000;
                                const period = Number(pulse.period) || 1;
                                const phase = (elapsedSeconds * 2 * Math.PI) / period;
                                const normalized = (Math.sin(phase) + 1) / 2;
                                const val = Number(pulse.min) + (Number(pulse.max) - Number(pulse.min)) * normalized;
                                filter.outerStrength = val;
                            }
                        }
                    });
                }
            };

            const checkChildren = (obj) => {
                updateTick(obj);
                if (obj.children) {
                    obj.children.forEach(c => {
                        if (c instanceof PIXI.Container) {
                            checkChildren(c);
                        }
                    });
                }
            };
            checkChildren(app.stage);
        });

        return app;
    };

})();
